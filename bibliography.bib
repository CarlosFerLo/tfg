  doi = {10.48550/arXiv.1409.7925},
  abstract = {This is a major update of the previous version. The methods of the paper are now fully constructive and the style is "formalization ready" with the emphasis on the possibility of formalization both in type theory and in constructive set theory without the axiom of choice. This is the third paper in a series started in 1406.7413. In it we construct a C-system \$CC(\textbraceleft\textbackslash cal C\textbraceright,p)\$ starting from a category \$\textbackslash cal C\$ together with a morphism \$p:\textbackslash widetilde\textbraceleft U\textbraceright\textbackslash rightarrow U\$, a choice of pull-back squares based on \$p\$ for all morphisms to \$U\$ and a choice of a final object of \$\textbackslash cal C\$. Such a quadruple is called a universe category. We then define universe category functors and construct homomorphisms of C-systems \$CC(\textbraceleft\textbackslash cal C\textbraceright,p)\$ defined by universe category functors. As a corollary of this construction and its properties we show that the C-systems corresponding to different choices of pull-backs and final objects are constructively isomorphic. In the second part of the paper we provide for any C-system CC three constructions of pairs \$((\textbraceleft\textbackslash cal C\textbraceright,p),H)\$ where \$(\textbraceleft\textbackslash cal C\textbraceright,p)\$ is a universe category and \$H:CC\textbackslash rightarrow CC(\textbraceleft\textbackslash cal C\textbraceright,p)\$ is an isomorphism. In the third part we define, using the constructions of the previous parts, for any category \$C\$ with a final object and fiber products a C-system \$CC(C)\$ and an equivalence \$(J\textasciicircum *,J\_*):C \textbackslash rightarrow CC\$.},
  keywords = {Mathematics - Category Theory,Mathematics - Logic},
